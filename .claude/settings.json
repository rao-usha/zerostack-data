{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-log-freshness.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/require-planning.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-spec-exists.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/remind-logging.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/run-tests-on-edit.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "SubToolCompleted",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/verify-completion.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact|startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/reinject-rules.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
