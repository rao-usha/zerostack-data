# Cloud (GCP Cloud SQL) — requires cloud-sql-proxy running on port 5435
# Usage: cp .env.cloud .env
# Prerequisites:
#   1. gcloud auth application-default login
#   2. ./cloud-sql-proxy.exe nexdata-cloud:us-central1:nexdata-pg --port=5435
DATABASE_URL=postgresql://nexdata:Nex2026@cloudsqlproxy:5432/nexdata
NEXDATA_ENV=cloud
